# ─────────────────────────────────────────────────────────────────────────
# devspace configuration — copy to `.env` and edit. NEVER commit your .env.
# Every value is validated at startup; bad/unsafe values fail closed (throw).
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED. Comma-separated absolute paths the server may expose.
# Use NARROW, dedicated project folders. The server REFUSES:
#   your home dir, "/", any dir that contains your home, and secrets dirs
#   (~/.ssh, ~/.aws, ~/.gnupg, ~/.kube, ~/.docker, …). It WARNS for
#   ~/Downloads, ~/Documents, ~/Desktop.
# Good:  /Users/you/code/sandbox,/Users/you/oss
ALLOWED_ROOTS=/Users/you/code/sandbox

# ── HTTP transport (devspace-http) ───────────────────────────────────────

# Bind address. Keep loopback. A tunnel (cloudflared/ngrok) fronts this for
# remote clients; do NOT bind 0.0.0.0 unless you fully understand the risk.
HOST=127.0.0.1
PORT=7676

# Public origin (NO path) when a tunnel fronts the server, e.g.
#   https://devspace.example.com
# Clients append /mcp themselves. Leave unset for pure-local use.
# PUBLIC_BASE_URL=

# Owner bearer token. REQUIRED for the HTTP transport (min 32 chars).
# If unset, an ephemeral one is generated and printed at startup (changes on
# restart) — set this to keep it stable. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# OWNER_TOKEN=

# DANGEROUS escape hatch: disable auth. ONLY allowed on loopback HOST with no
# PUBLIC_BASE_URL. Leave at 0 unless you really mean it.
# ALLOW_INSECURE_LOCAL=0

# DNS-rebinding / cross-origin protection (default on). The allowlists are
# derived from HOST:PORT (+ PUBLIC_BASE_URL) if you leave them blank. When
# fronting a tunnel for ChatGPT you MUST add the tunnel host explicitly.
# ENABLE_DNS_REBINDING_PROTECTION=true
# ALLOWED_HOSTS=127.0.0.1:7676,localhost:7676,devspace.example.com
# ALLOWED_ORIGINS=https://chatgpt.com,https://devspace.example.com

# ── Shell (run_command) — OFF by default ─────────────────────────────────

# Set to 1 to expose the run_command tool. Treat this as giving the client
# your local user account. Leave disabled unless you need it.
# ENABLE_SHELL=0

# restricted (default): only an allowlisted, read-only command set (git
#   status/diff/log/show/rev-parse/branch/describe/shortlog/tag/ls-files/blame).
# unrestricted: any binary (still argv-only, no shell). Requires the gate
#   below AND no PUBLIC_BASE_URL (local-only).
# SHELL_MODE=restricted
# ALLOW_UNRESTRICTED_SHELL=0

# Opt-in to logging a preview of shell commands (off by default — commands can
# contain sensitive arguments).
# LOG_SHELL_COMMANDS=0

# ── Resource caps (sane defaults; tune if needed) ────────────────────────
# MAX_READ_BYTES=2000000
# MAX_SEARCH_MATCHES=500
# MAX_SEARCH_FILE_BYTES=5000000
# SHELL_TIMEOUT_MS=30000
# SHELL_MAX_OUTPUT_BYTES=200000
