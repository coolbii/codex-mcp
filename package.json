{
  "name": "devspace",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted MCP server: narrow, auditable local file/search/edit/shell capabilities for AI clients (ChatGPT, Claude Desktop, any MCP host).",
  "type": "module",
  "engines": {
    "node": ">=20.12 <27"
  },
  "bin": {
    "devspace-http": "dist/bin/http.js",
    "devspace-stdio": "dist/bin/stdio.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:http": "node --env-file-if-exists=.env --import tsx --watch src/bin/http.ts",
    "dev:stdio": "node --env-file-if-exists=.env --import tsx src/bin/stdio.ts",
    "start:http": "node dist/bin/http.js",
    "start:stdio": "node dist/bin/stdio.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^9.0.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "optionalDependencies": {
    "re2": "^1.24.1"
  }
}
